package rules.triage.level1

import com.ftn.model.AgeGroup;
import com.ftn.model.Patient;

rule "Classify preschool patient"
    salience 1000
when
    $patient : Patient(ageGroup == null, preterm == false, age >= 3, age <= 5)
then
    modify($patient) {
        setAgeGroup(AgeGroup.PRESCHOOL);
    }
end
