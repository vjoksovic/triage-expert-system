package rules.triage.level1.age

import com.ftn.model.AgeGroup;
import com.ftn.model.Patient;

rule "Classify school-age patient"
    salience 1000
when
    $patient : Patient(ageGroup == null, preterm == false, age >= 6, age <= 12)
then
    modify($patient) {
        setAgeGroup(AgeGroup.SCHOOL_AGE);
    }
end
