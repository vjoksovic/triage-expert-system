package rules.triage.level2

import com.ftn.model.Diagnosis;
import com.ftn.model.DiagnosisType;
import com.ftn.model.Symptom;
import com.ftn.model.SymptomType;

rule "Diagnose sepsis preliminary"
    salience 100
when
    exists Symptom(type == SymptomType.FEVER)
    exists Symptom(type == SymptomType.TACHYCARDIA)
    not Diagnosis(type == DiagnosisType.SEPSIS_SUSPECTED)
then
    insert(new Diagnosis(DiagnosisType.SEPSIS_SUSPECTED,
        "Fever and tachycardia suggest preliminary sepsis."));
end
