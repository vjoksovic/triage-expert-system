package rules.triage.backward

import com.ftn.model.Patient
import com.ftn.model.SepsisSuspectedAnswer
import com.ftn.model.Symptom
import com.ftn.model.SymptomType
import com.ftn.model.VitalSignThresholds
import com.ftn.model.Vitals

// Goal-graph fact types used purely for backward chaining.
// They mirror the Location(x, y;) edges from the backward-example:
// the proof recurses over these facts using bound variables only
// (no eval, no literal recursion), so AND/OR composition derives reliably.
declare ProvenGoal
    name : String
end

declare OrGoal
    parent : String
    child : String
end

declare AndGoal
    parent : String
    left : String
    right : String
end

// A goal is proven if it is a detected atomic fact, OR one of its OR-children
// is proven, OR (for an AND goal) both of its children are proven.
query prove( String goal )
    ProvenGoal( goal; )
    or
    ( OrGoal( goal, $child; ) and prove( $child; ) )
    or
    ( AndGoal( goal, $left, $right; ) and prove( $left; ) and prove( $right; ) )
end

// --- Build the sepsis goal tree (structural edges) ---
rule "Init sepsis goal tree"
    agenda-group "backward"
    salience 100
when
    String( this == "isSepsaSuspected" )
    not AndGoal()
then
    insert(new OrGoal("hasInfectionRisk", "hasFever"));
    insert(new OrGoal("hasInfectionRisk", "hasConfusion"));
    insert(new AndGoal("hasHemodynamicInstability", "hasTachycardia", "hasHypotension"));
    insert(new AndGoal("isSepsaSuspected", "hasInfectionRisk", "hasHemodynamicInstability"));
end

// --- Detect atomic conditions as ProvenGoal facts ---
rule "Detect fever goal"
    agenda-group "backward"
    salience 50
when
    $p : Patient()
    $v : Vitals()
    eval(VitalSignThresholds.isFever($p, $v.getTemperature()))
    not ProvenGoal( name == "hasFever" )
then
    insert(new ProvenGoal("hasFever"));
end

rule "Detect confusion goal"
    agenda-group "backward"
    salience 50
when
    exists Symptom( type == SymptomType.CONFUSION )
    not ProvenGoal( name == "hasConfusion" )
then
    insert(new ProvenGoal("hasConfusion"));
end

rule "Detect tachycardia goal"
    agenda-group "backward"
    salience 50
when
    $p : Patient()
    $v : Vitals()
    eval(VitalSignThresholds.isTachycardia($p, $v.getPulse()))
    not ProvenGoal( name == "hasTachycardia" )
then
    insert(new ProvenGoal("hasTachycardia"));
end

rule "Detect hypotension goal"
    agenda-group "backward"
    salience 50
when
    $p : Patient()
    $v : Vitals()
    eval(VitalSignThresholds.isHypotension($p, $v.getSystolicBloodPressure()))
    not ProvenGoal( name == "hasHypotension" )
then
    insert(new ProvenGoal("hasHypotension"));
end

// --- Answer the top-level sepsis question ---
rule "Answer isSepsaSuspected query"
    agenda-group "backward"
when
    String( this == "isSepsaSuspected" )
    prove( "isSepsaSuspected"; )
    not SepsisSuspectedAnswer()
then
    insert(new SepsisSuspectedAnswer(
        true,
        "Patient profile meets criteria for suspected sepsis — infection risk with hemodynamic instability."));
end

rule "Answer isSepsaSuspected query - negative"
    agenda-group "backward"
    salience -10
when
    String( this == "isSepsaSuspected" )
    not prove( "isSepsaSuspected"; )
    not SepsisSuspectedAnswer()
then
    insert(new SepsisSuspectedAnswer(
        false,
        "Patient profile does not meet criteria for suspected sepsis."));
end
