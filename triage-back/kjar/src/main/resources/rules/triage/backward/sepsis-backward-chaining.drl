package rules.triage.backward

import com.ftn.model.AgeCategory
import com.ftn.model.Patient
import com.ftn.model.SepsisSuspectedAnswer
import com.ftn.model.Symptom
import com.ftn.model.SymptomType
import com.ftn.model.Vitals

query hasFever
    $p : Patient()
    $v : Vitals()
    eval(
        ($p.getAgeCategory() == AgeCategory.CHILD && $v.getTemperature() > 37.5)
        || ($p.getAgeCategory() == AgeCategory.ADULT && $v.getTemperature() > 38.0)
        || ($p.getAgeCategory() == AgeCategory.SENIOR && $v.getTemperature() > 37.8)
    )
end

query hasConfusion
    exists Symptom(type == SymptomType.CONFUSION)
end

query hasTachycardia
    $p : Patient()
    $v : Vitals()
    eval(
        ($p.getAgeCategory() == AgeCategory.SENIOR && $v.getPulse() > 90)
        || ($p.getAgeCategory() != null && $p.getAgeCategory() != AgeCategory.SENIOR && $v.getPulse() > 100)
    )
end

query hasHypotension
    $p : Patient()
    $v : Vitals()
    eval(
        ($p.getAgeCategory() == AgeCategory.CHILD && $v.getSystolicBloodPressure() < 90)
        || ($p.getAgeCategory() == AgeCategory.ADULT && $v.getSystolicBloodPressure() < 100)
        || ($p.getAgeCategory() == AgeCategory.SENIOR && $v.getSystolicBloodPressure() < 110)
    )
end

query hasInfectionRisk
    (
        hasFever() or
        hasConfusion()
    )
end

query hasHemodynamicInstability
    hasTachycardia()
    hasHypotension()
end

query isSepsaSuspected
    hasInfectionRisk()
    hasHemodynamicInstability()
end

rule "Answer isSepsaSuspected query"
    agenda-group "backward"
when
    String(this == "isSepsaSuspected")
    isSepsaSuspected()
    not SepsisSuspectedAnswer()
then
    insert(new SepsisSuspectedAnswer(
        true,
        "Patient profile meets criteria for suspected sepsis — infection risk with hemodynamic instability."));
end

rule "Answer isSepsaSuspected query - negative"
    agenda-group "backward"
    salience -10
when
    String(this == "isSepsaSuspected")
    not isSepsaSuspected()
    not SepsisSuspectedAnswer()
then
    insert(new SepsisSuspectedAnswer(
        false,
        "Patient profile does not meet criteria for suspected sepsis."));
end
